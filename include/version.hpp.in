#pragma once

#include <cstdint>
#include <string>

#define PANOMAP_VERSION "@PROJECT_VERSION@"
#define PANOMAP_VERSION_STRING "@PANOMAP_VERSION_STRING@"

namespace panomap {
struct Version {
    static constexpr uint32_t kMajor = @PROJECT_VERSION_MAJOR@;
    static constexpr uint32_t kMinor = @PROJECT_VERSION_MINOR@;
    static constexpr uint32_t kPatch = @PROJECT_VERSION_PATCH@;
};
} // namespace panomap

inline std::string panomap_version() {
    return PANOMAP_VERSION_STRING;
}
